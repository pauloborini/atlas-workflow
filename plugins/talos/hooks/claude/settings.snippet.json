{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node <TALOS_REPO>/hooks/claude/talos-hook.js pre-tool-use"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node <TALOS_REPO>/hooks/claude/talos-hook.js stop"
          }
        ]
      }
    ]
  }
}
